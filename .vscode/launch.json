{
	"version": "0.2.0",
	"inputs": [
		{
			"id": "sample",
			"type": "pickString",
			"description": "Select sample",
			"options": ["01_window", "02_triangle", "03_mesh", "04_model"],
			"default": "04_model"
		}
	],
	"configurations": [
		{
			"name": "Debug sample (cppvsdbg)",
			"type": "cppvsdbg",
			"request": "launch",
			"program": "${workspaceFolder}/samples/${input:sample}/${input:sample}.exe",
			"args": [],
			"cwd": "${workspaceFolder}/samples/${input:sample}",
			"console": "integratedTerminal",
			"preLaunchTask": "build"
		}
	]
}
