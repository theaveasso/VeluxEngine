{
	"version": "2.0.0",
	"inputs": [
		{
			"id": "sample",
			"type": "pickString",
			"description": "Select sample",
			"options": ["01_window", "02_triangle", "03_mesh", "04_voxel", "05_voxel_raycast"],
			"default": "05_voxel_raycast"
		},
		{
			"id": "testName",
			"type": "promptString",
			"description": "Test name (e.g. raycast_hits_solid_voxel)",
			"default": "raycast_hits_solid_voxel"
		}
	],
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "${workspaceFolder}/build.bat",
			"args": ["${input:sample}"],
			"options": { "cwd": "${workspaceFolder}" },
			"group": { "kind": "build", "isDefault": true },
			"presentation": { "reveal": "always", "panel": "shared", "clear": true },
			"problemMatcher": {
				"owner": "odin",
				"fileLocation": ["autoDetect", "${workspaceFolder}"],
				"pattern": {
					"regexp": "^(.*)\\((\\d+):(\\d+)\\)\\s+(Error|Warning):\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"severity": 4,
					"message": 5
				}
			}
		},
		{
			"label": "test",
			"type": "shell",
			"command": "odin",
			"args": [
				"test", "tests",
				"-collection:vlx=framework",
				"-collection:third_party=third_party",
				"-out:tests/tests.exe"
			],
			"options": { "cwd": "${workspaceFolder}" },
			"group": { "kind": "test", "isDefault": true },
			"presentation": { "reveal": "always", "panel": "shared", "clear": true },
			"problemMatcher": {
				"owner": "odin",
				"fileLocation": ["autoDetect", "${workspaceFolder}"],
				"pattern": {
					"regexp": "^(.*)\\((\\d+):(\\d+)\\)\\s+(Error|Warning):\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"severity": 4,
					"message": 5
				}
			}
		},
		{
			"label": "test (single)",
			"type": "shell",
			"command": "odin",
			"args": [
				"test", "tests",
				"-collection:vlx=framework",
				"-collection:third_party=third_party",
				"-define:ODIN_TEST_NAMES=tests.${input:testName}",
				"-out:tests/tests.exe"
			],
			"options": { "cwd": "${workspaceFolder}" },
			"group": "test",
			"presentation": { "reveal": "always", "panel": "shared", "clear": true },
			"problemMatcher": []
		},
		{
			"label": "run",
			"type": "process",
			"command": "${workspaceFolder}/samples/${input:sample}/${input:sample}.exe",
			"options": { "cwd": "${workspaceFolder}/samples/${input:sample}" },
			"dependsOn": "build",
			"presentation": { "reveal": "always", "panel": "shared" },
			"problemMatcher": []
		},
		{
			"label": "debug (RAD Debugger)",
			"type": "process",
			"command": "raddbg",
			"args": ["${workspaceFolder}/samples/${input:sample}/${input:sample}.exe"],
			"options": { "cwd": "${workspaceFolder}/samples/${input:sample}" },
			"dependsOn": "build",
			"problemMatcher": []
		},
		{
			"label": "debug (RenderDoc capture)",
			"type": "process",
			"command": "C:/Program Files/RenderDoc/renderdoccmd.exe",
			"args": [
				"capture",
				"--working-dir", "${workspaceFolder}/samples/${input:sample}",
				"${workspaceFolder}/samples/${input:sample}/${input:sample}.exe"
			],
			"options": { "cwd": "${workspaceFolder}/samples/${input:sample}" },
			"dependsOn": "build",
			"problemMatcher": []
		},
		{
			"label": "open RenderDoc UI",
			"type": "process",
			"command": "C:/Program Files/RenderDoc/qrenderdoc.exe",
			"problemMatcher": []
		}
	]
}
